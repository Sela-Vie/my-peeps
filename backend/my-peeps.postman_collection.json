{
  "info": {
    "name": "My Peeps",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api"
    },
    {
      "key": "person_id",
      "value": "1"
    },
    {
      "key": "data_entry_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "People",
      "item": [
        {
          "name": "List all",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/people"
          }
        },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/people",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name_display\": \"fake_John\",\n  \"name_full\": \"fake_John Doe\",\n  \"birth_date\": 15,\n  \"birth_month\": 6,\n  \"birth_year\": 1990\n}"
            }
          }
        },
        {
          "name": "Show",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/people/{{person_id}}"
          }
        },
        {
          "name": "Update",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/people/{{person_id}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name_display\": \"fake_Jane\",\n  \"name_full\": \"fake_Jane Smith\"\n}"
            }
          }
        },
        {
          "name": "Delete",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/people/{{person_id}}"
          }
        }
      ]
    },
    {
      "name": "Person Data Entries",
      "item": [
        {
          "name": "List all for person",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/people/{{person_id}}/person-data-entries"
          }
        },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/people/{{person_id}}/person-data-entries",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data_entry_content\": \"Some notes about this person...\"\n}"
            }
          }
        },
        {
          "name": "Show",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/people/{{person_id}}/person-data-entries/{{data_entry_id}}"
          }
        },
        {
          "name": "Update",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/people/{{person_id}}/person-data-entries/{{data_entry_id}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data_entry_content\": \"Updated notes...\"\n}"
            }
          }
        },
        {
          "name": "Delete",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/people/{{person_id}}/person-data-entries/{{data_entry_id}}"
          }
        }
      ]
    }
  ]
}
